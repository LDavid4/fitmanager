{
  "name": "fitmanager",
  "version": "1.0.0",
  "description": "FitManager - Sistem za upravljanje teretanom",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "server": "nodemon server/server.js",
